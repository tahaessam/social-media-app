{
  "name": "social-media-app",
  "version": "1.0.0",
  "description": "A modern social media application built with Node.js, Express, and TypeScript",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "start:dev": "concurrently \"npm run build -- --watch\" \"npm run start:server\"",
    "start:server": "npm run build && node dist/index.js",
    "test": "echo \"No tests specified yet\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.17.3",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "redis": "^4.6.11",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.17.10",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^6.4.16",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
