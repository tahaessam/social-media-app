{
  "name": "social-media-app",
  "version": "1.0.0",
  "description": "A modern social media application built with Node.js, Express, and TypeScript",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "start:dev": "concurrently \"npm run build -- --watch\" \"npm run start:server\"",
    "start:server": "npm run build && node dist/index.js",
    "test": "echo \"No tests specified yet\""
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "mongoose": "^9.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.19.39",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
