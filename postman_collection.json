            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postId\": \"{{postId}}\",\n  \"content\": \"This is a comment.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/comments",
