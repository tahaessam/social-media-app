              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postId}}"]
            }
          }
        },
        {
          "name": "POST /posts/:id/reactions",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reactionType\": \"like\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}/reactions",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postId}}", "reactions"]
            }
          }
        },
        {
          "name": "GET /posts/:id/reactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{postId}}/reactions",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{postId}}", "reactions"]
            }
          }
        }
      ]
    },
