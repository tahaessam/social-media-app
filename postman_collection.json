{
  "info": {
    "name": "Pulse Chat / Social Media API",
    "description": "Updated collection for auth, chat, posts, comments, and friend requests. Signup/login auto-save token + userId.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "email", "value": "alice@example.com" },
    { "key": "password", "value": "Pass123" },
    { "key": "fullName", "value": "Alice" },
    { "key": "lookupEmail", "value": "bob@example.com" },
    { "key": "recipientId", "value": "" },
    { "key": "conversationId", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "commentId", "value": "" },
    { "key": "verificationToken", "value": "" },
    { "key": "resetToken", "value": "" },
    { "key": "newPassword", "value": "NewPass123" },
    { "key": "otp", "value": "" },
    { "key": "receiverId", "value": "" },
    { "key": "requestId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/ping", "host": ["{{baseUrl}}"], "path": ["ping"] }
          }
        },
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/", "host": ["{{baseUrl}}"], "path": [] }
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "POST /auth/signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.collectionVariables.set('token', json.data.token);",
                  "if (json?.data?.id) pm.collectionVariables.set('userId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"fullName\": \"{{fullName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "description": "Registers user (auto-verified in dev) and returns token + id."
          }
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.collectionVariables.set('token', json.data.token);",
                  "if (json?.data?.id) pm.collectionVariables.set('userId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "GET /auth/lookup",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.id) {",
                  "  pm.collectionVariables.set('recipientId', json.id);",
                  "  pm.collectionVariables.set('receiverId', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/auth/lookup?email={{lookupEmail}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "lookup"],
              "query": [{ "key": "email", "value": "{{lookupEmail}}" }]
            },
            "description": "Find a user by email to start a chat. Saves recipientId."
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "POST /auth/confirm-email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verificationToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/confirm-email",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "confirm-email"]
            }
          }
        },
        {
          "name": "PUT /auth/update-password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"{{password}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/update-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "update-password"]
            }
          }
        },
        {
          "name": "POST /auth/forget-password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/auth/forget-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forget-password"]
            }
          }
        },
        {
          "name": "POST /auth/reset-password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            }
          }
        },
        {
          "name": "POST /auth/send-otp",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/auth/send-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "send-otp"]
            }
          }
        },
        {
          "name": "POST /auth/verify-otp",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) pm.collectionVariables.set('token', json.data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/verify-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "verify-otp"]
            }
          }
        },
        {
          "name": "POST /auth/resend-otp",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{email}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/auth/resend-otp",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "resend-otp"]
            }
          }
        },
        {
          "name": "POST /auth/device-token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"fcmToken\": \"YOUR_FCM_TOKEN\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/auth/device-token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "device-token"]
            }
          }
        },
        {
          "name": "DELETE /auth/device-token",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/auth/device-token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "device-token"]
            }
          }
        },
        {
          "name": "GET /auth/google",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google"]
            }
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "GET /chats",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (Array.isArray(json) && json[0]?.id) {",
                  "  pm.collectionVariables.set('conversationId', json[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/chats",
              "host": ["{{baseUrl}}"],
              "path": ["chats"]
            },
            "description": "List conversations with participant details."
          }
        },
        {
          "name": "GET /chats/:conversationId/messages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/chats/{{conversationId}}/messages",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "{{conversationId}}", "messages"]
            }
          }
        },
        {
          "name": "POST /chats/send",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.conversationId) pm.collectionVariables.set('conversationId', json.conversationId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientId\": \"{{recipientId}}\",\n  \"content\": \"Hello from Postman\",\n  \"conversationId\": \"{{conversationId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chats/send",
              "host": ["{{baseUrl}}"],
              "path": ["chats", "send"]
            },
            "description": "Send a DM. conversationId is optional for a new chat — leave empty or omit for first message. Run lookup first to fill recipientId."
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
